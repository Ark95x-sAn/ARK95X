# ============================================
# ARK95X Environment Configuration
# Copy this file to .env and update values
# ============================================

# --- Ollama Configuration ---
OLLAMA_HOST=http://ollama:11434
BENCHMARK_MODELS=gemma4,llama3,mistral

# --- n8n Workflow Engine ---
N8N_AUTH=true
N8N_USER=ark95x
N8N_PASS=changeme
WEBHOOK_URL=http://localhost:5678
N8N_ENCRYPTION_KEY=ark95x-secret-change-this

# --- Toast POS Audit ---
VOID_THRESHOLD=5.0
COMP_THRESHOLD=3.0
ALERT_WEBHOOK=

# --- Watchdog ---
CHECK_INTERVAL=300

# --- Logging ---
LOG_LEVEL=INFO

# --- Dashboard ---
DASHBOARD_PORT=8501
